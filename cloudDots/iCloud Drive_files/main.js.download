"FileRecovery.CloseWarning.CloseAnyway":"Close Anyway","FileRecovery.Progress.FilesRestored.One":"1 of %{totalItems} files restored.","FileRecovery.Progress.FilesRestored.Two":"2 of %{totalItems} files restored.","FileRecovery.Progress.FilesRestored.Many":"%{restoredItems} of %{totalItems} files restored.","FileRecovery.Progress.StayOnPage":"Keep this page open until all files are restored.","FileRecovery.Progress.AriaLabel.One":"Restoration progress: %{restoredItems} of %{totalItems} file restored","FileRecovery.Progress.AriaLabel.Two":"Restoration progress: %{restoredItems} of %{totalItems} files restored","FileRecovery.Progress.AriaLabel.Many":"Restoration progress: %{restoredItems} of %{totalItems} files restored","FileRecovery.Success.Title.One":"File Restored","FileRecovery.Success.Title.Many":"%{count} Files Restored","FileRecovery.Success.Description.One":"It’s been restored to its original location.","FileRecovery.Success.Description.Many":"They’ve been restored to their original locations.","FileRecovery.Purge.Success.Title":"Files Deleted Successfully","FileRecovery.Purge.Success.Description":"The selected files have been permanently deleted.","FileRecovery.Cancel.Title":"Cancel Restoration","FileRecovery.Cancel.Description.One":"%{restoredItems} of 1 file has been restored. If you cancel, the file won't be restored.","FileRecovery.Cancel.Description.Two":"%{restoredItems} of 2 files have been restored. If you cancel, %{remainingItems} files won't be restored.","FileRecovery.Cancel.Description.Two.OneRemaining":"%{restoredItems} of 2 files have been restored. If you cancel, 1 file won't be restored.","FileRecovery.Cancel.Description.Many":"%{restoredItems} of %{totalItems} files have been restored. If you cancel, %{remainingItems} files won't be restored.","FileRecovery.Cancel.Description.Many.OneRemaining":"%{restoredItems} of %{totalItems} files have been restored. If you cancel, 1 file won't be restored.","FileRecovery.Cancel.Continue":"Continue Restoration","FileRecovery.Cancel.Cancel":"Cancel Restoration","FileRecovery.Cancel.Button":"Cancel","FileRecovery.Progress.PopupAriaLabel":"File Restoration Progress","Truncate.ExtraItems.Zero":"","Truncate.ExtraItems.One":"And 1 more","Truncate.ExtraItems.Two":"And 2 more","Truncate.ExtraItems.Many":"And %{count} more","CustomEmailDomainTile.Status.InProgress":"%{domain} (pending)","DescribePlanPricing.Monthly":"%{price}/month","DescribePlanPricing.Yearly":"%{price}/year","DescribePlanPricing.Monthly.WithSpace":"%{price} / month","DescribePlanPricing.Yearly.WithSpace":"%{price} / year","DescribePlanPricing.Free":"Free","PlanDetailsPage.Title.Lite":"iCloud Plan","PlanDetailsPage.Title":"Your iCloud Plan","PlanDetailsPage.TitleWithName":"%{firstName}’s iCloud Plan","PlanDetailsPage.Lite.Details":"Web-Only Access with 1 GB storage","PlanDetailsPage.Lite.Price":"Free","PlanDetailsPage.Standard.Details":"5 GB storage","PlanDetailsPage.Standard.Price":"Free","PlanDetailsPage.Plus.Details":"iCloud+ with %{storage} storage","PlanDetailsPage.Plus.Free":"Free","PlanDetailsPage.MAID.Details":"%{storage} storage","PlanDetailsPage.MAID.Price":"Included with your Managed Apple Account","PlanDetailsPage.AppleOne":"Included in Apple One","PlanDetailsPage.ExtraStorage":"%{storage} Extra Storage","PlanDetailsPage.SharedBy":"Shared by %{planOwnerName} (Family Sharing)","PlanDetailsPage.ChangePlanSection.Title.Lite":"About Web-Only Access to iCloud","PlanDetailsPage.ChangePlanSection.Body.Lite":"Includes 1 GB of storage to share and collaborate on documents, spreadsheets, and presentations. If you have an iPhone, iPad, iPod touch, or Mac, sign in to iCloud on your device to get immediate access to all iCloud features and 5 GB of free storage. From your device, you can also upgrade to iCloud+ to access premium features such as iCloud Private Relay, Hide My Email, and HomeKit Secure Video.","PlanDetailsPage.ChangePlanSection.Body.Lite.LearnMore.Title":"Learn more","PlanDetailsPage.ChangePlanSection.LearnMore.Text":"View #{iCloudPlusLink}","PlanDetailsPage.ChangePlanSection.LearnMore.Link.Title":"iCloud+ Plans","PlanDetailsPage.Includes":"Includes","PlanDetailsPage.Included":"Included","PlanDetailsPage.Bullets.Lite.Storage":"1 GB of storage","PlanDetailsPage.Bullets.Lite.FeaturesHeader":"Access on icloud.com to:","PlanDetailsPage.Bullets.Standard.Storage":"5 GB of storage","PlanDetailsPage.Bullets.StandardPlus.FeaturesHeader":"Apps and Features","PlanDetailsPage.Bullets.Plus.Storage":"%{storage} of storage","PlanDetailsPage.Bullets.Plus.Premium.Header":"Premium","PlanDetailsPage.Bullets.Plus.Premium.PrivateRelay":"Private Relay","PlanDetailsPage.Bullets.Plus.Premium.HideMyEmail":"Hide My Email","PlanDetailsPage.Bullets.Plus.Premium.CustomEmailDomain":"Custom Email Domain","PlanDetailsPage.Bullets.Plus.Premium.HomeKitSecureCam.One":"Support for one HomeKit Secure Video Camera","PlanDetailsPage.Bullets.Plus.Premium.HomeKitSecureCam.Two":"Support for two HomeKit Secure Video Cameras","PlanDetailsPage.Bullets.Plus.Premium.HomeKitSecureCam.Many":"Support for %{count} HomeKit Secure Video Cameras","PlanDetailsPage.Bullets.Plus.Premium.HomeKitSecureCam.Unlimited":"Support for unlimited HomeKit Secure Video Cameras","PlanDetailsPage.Bullets.Plus.Premium.FamilySharing":"Family Sharing","PlanDetailsPage.Bullets.Features.Drive":"iCloud Drive","PlanDetailsPage.Bullets.Features.Notes":"Notes","PlanDetailsPage.Bullets.Features.Contacts":"Contacts","PlanDetailsPage.Bullets.Features.Pages":"Pages","PlanDetailsPage.Bullets.Features.Numbers":"Numbers","PlanDetailsPage.Bullets.Features.Keynote":"Keynote","PlanDetailsPage.Bullets.Features.Photos":"iCloud Photos","PlanDetailsPage.Bullets.Features.Backup":"iCloud Backup","PlanDetailsPage.Bullets.Features.Mail":"iCloud Mail","PlanDetailsPage.Bullets.Features.PasswordAndKeychain":"iCloud Passwords and Keychain","PlanDetailsPage.Included.iCloudFeatures.Link.Title":"apps and features that use iCloud","PlanDetailsPage.Included.iCloudMail.Link.Title":"iCloud Mail address","PlanDetailsPage.Included.StandardPlus.LearnMore.Features":"See all #{iCloudFeaturesLink}","PlanDetailsPage.Included.StandardPlus.LearnMore.Mail":"Learn more about #{iCloudMailLink}","PlanDetailsPage.Downgrade.Link.Title":"Downgrade or cancel your iCloud+","ICloudPlusPage.Title":"iCloud+ Features","ICloudPlusPage.Description":"Your iCloud+ Plan gives you storage for all your data in iCloud, plus premium features like Private Relay and Hide My Email. Manage or learn more about each of these features.","ICloudPlusPage.PlanNavLink":"View Plan","ICloudPlusPage.OnlyOnDevices.Title":"Only on your devices","ICloudPlusPage.OnlyOnDevices.Description":"Some of your iCloud+ features can only be set up and managed from an Apple device. Learn more about each feature, and get links to manage them on your devices.","ICloudPlusPage.ModalContent.LearnMore":"Learn more","ICloudPlusPage.PrivateRelayModalContent.Title":"Private Relay","ICloudPlusPage.PrivateRelayModalContent.SubTitle":"Protect your internet browsing","ICloudPlusPage.PrivateRelayModalContent.Section.Description":"Private Relay hides your IP address and browsing activity in Safari. This protects your unencrypted internet traffic so that no one, including Apple, can see who you are or what sites you’re visting.","ICloudPlusPage.HomeKitSecureVideoModalContent.Title":"HomeKit Secure Video","ICloudPlusPage.HomeKitSecureVideoModalContent.SubTitle.One":"For 1 Home Security Camera","ICloudPlusPage.HomeKitSecureVideoModalContent.SubTitle.Two":"For up to 2 Home Security Cameras","ICloudPlusPage.HomeKitSecureVideoModalContent.SubTitle.Many":"For up to %{count} Home Security Cameras","ICloudPlusPage.HomeKitSecureVideoModalContent.SubTitle.Unlimited":"For unlimited Home Security Cameras","ICloudPlusPage.HomeKitSecureVideoModalContent.Section.Description":"Add your home security cameras in the Home app to record your footage and view it from anywhere. It’s all end-to-end encrypted, and none of the video counts toward your iCloud storage. You can access HomeKit Secure Video on your iPhone, iPad, iPod touch, Mac, or Apple TV.","ICloudPlusPage.FamilySharingModalContent.Title":"Family Sharing","ICloudPlusPage.FamilySharingModalContent.SubTitle.NotSharing":"Share your plan with up to 5 family members","ICloudPlusPage.FamilySharingModalContent.SubTitle.Sharing":"Shared by %{name}","ICloudPlusPage.FamilySharingModalContent.Section.Description.NotSharing":"With Family Sharing, you can share your iCloud+ subscription with up to 5 other people at no extra cost. They’ll automatically get access to iCloud+ storage and privacy features like Private Relay and Hide My Email.","ICloudPlusPage.FamilySharingModalContent.Section.Description.Sharing":"You are using the iCloud+ plan shared by %{name}.","AppLibraryHomeTile.Heading":"Apps","StoragePage.Title.Lite":"iCloud Storage","StoragePage.Title":"Your iCloud Storage","StoragePage.TitleWithName":"%{firstName}’s iCloud Storage","StoragePage.Description.WebOnly":"Use your storage to store, share, and collaborate on documents, spreadsheets, presentations, and files.","StoragePage.Description.Standard":"Use your iCloud storage to keep your most important information—like your photos, files, backups, and more—secure, up to date, and available across all your devices.","StoragePage.Description.Neutral":"iCloud Storage can be used for iCloud backups, to keep photos and videos stored in iCloud Photos, to keep documents up to date in iCloud Drive, and more.","StoragePage.Badge":"View Plan","StoragePage.Callout.Content.WebOnly":"To manage your storage, open iCloud Drive and choose the files you want to keep and delete those that you don’t need anymore.","StoragePage.Callout.ContinueButton.Title.WebOnly":"Open iCloud Drive…","StoragePage.AppCounts.Mail.All":"All Email Messages","StoragePage.StorageWarning.AlmostFull":"Your iCloud storage is almost full. Upgrade your plan to get more space.","StoragePage.StorageWarning.AlmostFull.NoUpgrade":"Your iCloud storage is almost full. If you run out, new data won’t be synced to iCloud.","StoragePage.StorageWarning.Full":"Your iCloud storage is full. Upgrade your plan to get more space.","StoragePage.StorageWarning.Full.NoUpgrade":"Your iCloud storage is full. If you run out, new data won’t be synced to iCloud.","CloudOS.Button.Cancel.Title":"Cancel","CloudOS.Button.Download.Title":"Download","CloudOS.Button.GoBack.Title":"Go Back","CloudOS.Button.OK.Title":"OK","CloudOS.MailDrop.Download.Title":"%{shareTitle} • %{size}","CloudOS.MailDrop.Download.Size":"size <b>%{size}</b>","CloudOS.MailDrop.Download.Description":"This file was uploaded by the sender using Mail Drop.","CloudOS.MailDrop.Downloading.Title":"Your download will begin shortly…","CloudOS.MailDrop.Downloading.Description":"Check your downloads folder for:","MailDropPage.Download.Button.Text":"Download to your device","MailDropPage.Description":"Mail Drop Attachment","MailDropPage.Download.Item.Description":"%{fileType} • %{size}","MailDropPage.Error.Title.Expired":"Expired","MailDropPage.Error.Description.Expired":"This file is no longer available for download. Ask the sender to send it again.","MailDropPage.Error.Title.NotFound":"File Not Found","MailDropPage.Error.Description.NotFound":"Check the address or ask the sender to send it again.","MailDropPage.Error.Title.MaxDownloads":"File No Longer Available","MailDropPage.Error.Description.MaxDownloads":"The file is no longer available because it has been downloaded the maximum number of times. Ask the sender to send it again.","MailDropPage.Error.Title":"Something Went Wrong","MailDropPage.Error.Description":"There was a problem downloading the file. Try again later.","CloudOS.LocalizationFormatter.FileSize.bytes":"%{value} bytes","CloudOS.LocalizationFormatter.FileSize.KB":"%{value} KB","CloudOS.LocalizationFormatter.FileSize.MB":"%{value} MB","CloudOS.LocalizationFormatter.FileSize.GB":"%{value} GB","CloudOS.LocalizationFormatter.FileSize.TB":"%{value} TB","CloudOS.LocalizationFormatter.DecimalSymbol":".","CloudOS.LandingPage.description":"The best place for all your photos, files, notes, mail, and more.","CloudOS.LandingPage.description.gcbd":"Your home on the web for iCloud photos, files, notes, mail, and more.","CloudOS.LandingPage.Animation.Description":"Animation showing different users’ Memojis surrounded by the icons of the apps the user personally uses most","CloudOS.LandingPage.iCloudPlusTile.Title":"More storage, plus features to protect your privacy and connect with friends","CloudOS.LandingPage.iCloudPlusTile.Description":"Upgrade to iCloud+ to get more storage, plan events with Apple Invites, and have peace of mind with privacy features like iCloud Private Relay, Hide My Email, and HomeKit Secure Video. You can even share your subscription with your family. Learn more at #{icloudPlusLink}.","CloudOS.LandingPage.iCloudPlusTile.Description.gcbd":"Upgrade to iCloud+ to get more storage and additional features like Hide My Email and HomeKit Secure Video. You can even share your subscription with your family. Learn more at #{icloudPlusLink}.","CloudOS.LandingPage.iCloudPlusTile.Description.LinkLabel":"apple.com/icloud","CloudOS.LandingPage.iCloudPlusTile.Image.Description":"Graphic depicting the icons for various iCloud+ benefits, including up to 12TB of storage","CloudOS.LandingPage.iCloudWeb.Title":"Easily access apps and data from your iPhone on the web","CloudOS.LandingPage.iCloudWeb.Description":"iCloud is essential for keeping personal information from your devices safe, up to date, and available wherever you are. At iCloud.com, you can access your photos, files, and more from any web browser. Changes you make will sync to your iPhone and other devices, so you’re always up to date.","CloudOS.LandingPage.iCloudWeb.Image.Description":"Collection of icons for apps available on iCloud.com, including Mail, Find My, and Reminders","CloudOS.LandingPage.Find.DisplayName":"Find Devices","CloudOS.LandingPage.Find.Description":"Find your iPhone, iPad, Mac, Apple Watch, AirPods, or Beats. Or help locate Family Sharing devices.","CloudOS.LandingPage.Mail.Description":"Private, secure, and personal email from Apple.","CloudOS.LandingPage.Photos.Description":"Easily view and share your photos and videos stored in iCloud on any device and the web.","CloudOS.LandingPage.IClouddrive.Description":"Easily view and share all your files stored in iCloud on any device and on the web.","CloudOS.LandingPage.Notes.Description":"Capture thoughts or detailed notes. Your notes are always up to date on any device and on the web.","CloudOS.LandingPage.Reminders.Description":"Your reminders are always up to date on any device and on the web.","CloudOS.LandingPage.Calendar.Description":"Organize your time with iCloud Calendar. It’s always up to date on any device and on the web.","CloudOS.LandingPage.Pages.Description":"Create stunning documents with Pages. Collaborate with your team on any device and on the web.","CloudOS.LandingPage.Numbers.Description":"Bring your data to life with Numbers. Collaborate with your team on any device and on the web.","CloudOS.LandingPage.Keynote.Description":"Create memorable presentations with Keynote. Collaborate with your team on any device or on the web.","CloudOS.LandingPage.Contacts.Description":"Access all your contacts stored in iCloud. They’re always up to date on any device and on the web.","CloudOS.LandingPage.NewsPublisher.Description":"News Publisher is the iCloud application for publishing articles to Apple News.","CloudOS.LandingPage.Directory.Description":"Access all your business contacts stored in iCloud. They’re always up to date on any device and on the web.","CloudOS.LandingPage.NewsPublisher.LearnMoreLink.Text":"Learn more about publishing on Apple News","CloudOS.LandingPage.LearnMoreLink.Text":"Learn more about %{applicationNameToBeDisplayed}","CloudOS.LandingPage.Unsupported.Phone.Description":"To use %{applicationNameToBeDisplayed} on iCloud.com, switch to a tablet or desktop browser.","CloudOS.LandingPage.Unsupported.Phone.Subdescription":"Other apps, including Mail, Photos, and Drive, are available on this browser.","CloudOS.LandingPage.Unsupported.Tablet.Description":"To use %{applicationNameToBeDisplayed} on iCloud.com, switch to a desktop browser.","CloudOS.LandingPage.Unsupported.Tablet.Subdescription":"Other apps, including Mail, Photos, and Drive, are available on this browser.","CloudOS.LandingPage.Unsupported.LiteAccount.Description":"%{applicationNameToBeDisplayed} isn’t available for your Apple Account","CloudOS.LandingPage.Unsupported.LiteAccount.Subdescription":"The Apple Account %{appleId} has web-only access to iCloud, which doesn’t include %{applicationNameToBeDisplayed}. You can use other apps, like Drive, Notes and Numbers. To use %{applicationNameToBeDisplayed}, sign in with an Apple Account you use with an Apple device.","CloudOS.LandingPage.Unsupported.LiteAccount.SignOut":"Sign Out","CloudOS.LandingPage.Unsupported.Subdescription":"%{applicationNameToBeDisplayed} is not available for your account.","CloudOS.LandingPage.Mail.Subdescription":"Sign in with your Apple Account to access your mail or create a new mail account.","CloudOS.LandingPage.Mail.Tile.A.Title":"Seamlessly Integrated","CloudOS.LandingPage.Mail.Tile.A.Description":"iCloud Mail seamlessly integrates into the Mail app on your Apple devices with powerful features like smart search, undo send, rich links, remind me, and more. And of course, you can access your mail from anywhere on icloud.com.","CloudOS.LandingPage.Mail.Tile.A.CategorizationSupported.Title":"Email, by Apple","CloudOS.LandingPage.Mail.Tile.A.CategorizationSupported.Description":"iCloud Mail seamlessly integrates into the Mail app on your Apple devices with powerful features like categorization, smart search, undo send, rich links, remind me, and more. And of course, you can access your mail from anywhere on icloud.com.","CloudOS.LandingPage.Mail.Tile.B.Title":"Always Ad-free","CloudOS.LandingPage.Mail.Tile.B.Description":"Your email messages are never scanned for advertising and you’ll never see ads in your inbox.","CloudOS.LandingPage.Mail.Tile.Cleanup.Title":"iCloud Mail Cleanup","CloudOS.LandingPage.Mail.Tile.Cleanup.Description":"Unsubscribe and remove unwanted or older messages to further reduce noise from your inbox.","CloudOS.LandingPage.Mail.Tile.C.Title":"Private and Secure","CloudOS.LandingPage.Mail.Tile.C.Description":"Mail Privacy Protection prevents senders from gathering information about your Mail activity. It hides your IP address so senders can’t connect it to your other online activity or determine your location. Two-factor authentication and encryption helps keep your email secure.","CloudOS.LandingPage.Mail.Tile.D.Title":"Hide My Email","CloudOS.LandingPage.Mail.Tile.D.Description":"With iCloud+, you’ll get access to Hide My Email which lets you generate a unique, random email addresses that forward to your inbox - so you can send and receive email without sharing your real address.","CloudOS.LandingPage.Mail.Tile.E.Title":"Personalize with a Custom Domain","CloudOS.LandingPage.Mail.Tile.E.Description":"With iCloud+, you can customize your email address with a personal domain name. Import a domain you already own or purchase a new one right from Mail settings.","CloudOS.LandingPage.Mail.Tile.F.Title":"Spam and Phishing Protection","CloudOS.LandingPage.Mail.Tile.F.Description":"iCloud Mail uses industry leading spam filtering technology. Digitally certified brand indicators help keep you safe from fraudulent phishing emails.","CloudOS.LandingPage.Mail.FAQ.SeeAll":"See all FAQ","CloudOS.LandingPage.Mail.FAQ.A.Question":"Is iCloud Mail free?","CloudOS.LandingPage.Mail.FAQ.A.Answer":"Yes. When you create an Apple Account and set up your iCloud Mail account, you’ll receive 5GB of free iCloud storage for your mail, photos and other content. You can get additional space and features like custom domain support and Hide My Email by upgrading to iCloud+.","CloudOS.LandingPage.Mail.FAQ.B.Question":"What is a custom email domain? How do I get one?","CloudOS.LandingPage.Mail.FAQ.B.Answer":"A custom email domain allows you to personalize your mail address for yourself or for your small business. For example instead of name@icloud.com, your address could be name@yourdomain.com. You can set up a domain you already own, or easily purchase one, right from Settings. Learn more about how to set up a custom domain #{customDomainLink}. Setting up a custom domain requires iCloud+.","CloudOS.LandingPage.Mail.FAQ.B.Answer.CustomDomainLinkText":"here","CloudOS.LandingPage.Mail.FAQ.C.Question":"Does iCloud Mail support email aliases?","CloudOS.LandingPage.Mail.FAQ.C.Answer":"Yes. Every iCloud Mail user can add up to three additional @icloud.com email addresses to your account for categorizing messages or keeping a particular address private.","CloudOS.LandingPage.Mail.FAQ.D.Question":"What is iCloud+?","CloudOS.LandingPage.Mail.FAQ.D.Answer":"iCloud+ is Apple’s premium cloud service that gives you the storage you need for all the photos, documents, notes, and more you store in iCloud, plus premium features like Custom Email Domains, Hide My Email, Private Relay, and HomeKit Secure Video.","CloudOS.LandingPage.Plan.DisplayName":"iCloud+","CloudOS.LandingPage.Plan.Description":"Get more storage with iCloud+ to save your photos, files, mail, and more along with enhanced privacy features to protect you and your data. It’s all the power of iCloud. Plus.","CloudOS.LandingPage.Plan.SigninButtonText":"Upgrade to iCloud+","CloudOS.LandingPage.Plan.Subdescription":"Sign in to view, upgrade or manage your plan.","CloudOS.LandingPage.Plan.Tile.A.Title":"Everything that matters. Saved and sound.","CloudOS.LandingPage.Plan.Tile.A.Description":"Keep a lifetime of photos, files, notes, messages, and more safely stored in iCloud. #{iCloudPlusPlansLink}","CloudOS.LandingPage.Plan.Tile.LinkText":"Choose the plan that’s right for you.","CloudOS.LandingPage.Plan.Tile.B.Title":"More privacy. More protection. More peace of mind.","CloudOS.LandingPage.Plan.Tile.B.Description":"iCloud+ gives you access to enhanced privacy features like iCloud Private Relay, Hide My Email, and HomeKit Secure Video.","CloudOS.LandingPage.Plan.FAQ.A.Question":"What is iCloud+?","CloudOS.LandingPage.Plan.FAQ.A.Answer":"iCloud+ gives you additional storage for all your data plus powerful features like iCloud Private Relay, Hide My Email, Custom Email Domain, and HomeKit Secure Video to help protect your privacy online.","CloudOS.LandingPage.Plan.FAQ.B.Question":"How do I upgrade to iCloud+?","CloudOS.LandingPage.Plan.FAQ.B.Answer":"It’s easy. Just click on the upgrade button on this page, or go to iCloud Settings on your iPhone, iPad, or Mac to upgrade to iCloud+.","CloudOS.LandingPage.Plan.FAQ.C.Question":"Can my family share an iCloud+ plan?","CloudOS.LandingPage.Plan.FAQ.C.Answer":"Yes. You can share any iCloud+ plan with up to five other people in your Family Sharing group. Everyone will get access to the storage they need, along with features that keep them in control of their privacy, at no additional cost per user. A single subscription can cover everyone in your household, and each person’s files, documents, and other personal information remain private and separate.","CloudOS.LandingPage.FAQ.Title":"Questions? Answered.","CloudOS.LandingPage.Invites.Tile.A.Title":"Get the Party Started","CloudOS.LandingPage.Invites.Tile.A.Description":"Customize your invitation with a curated background or photo of your own. You can even add details with Apple Music, Photos, Maps, and more to bring your event to life.","CloudOS.LandingPage.Invites.Tile.B.Title":"Everyone’s Invited","CloudOS.LandingPage.Invites.Tile.B.Description":"All of your guests can RSVP easily, whether from the iPhone app or from iCloud.com on any device. They can even add to collaborative playlists and shared photo albums for the event.","CloudOS.LandingPage.Invites.Tile.C.Title":"Party on with iCloud+","CloudOS.LandingPage.Invites.Tile.C.Description":"iCloud+ subscribers get full access to Apple Invites. There are no ads, additional costs, or limits on the amount of events you can host.","CloudOS.LandingPage.Invites.Description":"Create unique invitations for life’s most exciting moments.","CloudOS.LandingPage.Invites.FAQ.A.Title":"How do I get Apple Invites?","CloudOS.LandingPage.Invites.FAQ.A.Content":"Apple Invites is available to download in the App Store and on iCloud.com.","CloudOS.LandingPage.Invites.FAQ.B.Title":"How do I send invitations with Apple Invites?","CloudOS.LandingPage.Invites.FAQ.B.Content":"It’s easy to create and invite others to Apple Invites. Just copy the link and send to family and friends on any messaging platform. Up to 100 guests can participate per event, and there’s no limit on how many events you can host.","CloudOS.LandingPage.Invites.FAQ.C.Title":"Do invitees need to have an Apple device with the app to attend an event?","CloudOS.LandingPage.Invites.FAQ.C.Content":"Apple Invites is for everyone. Guests don’t need the app, an Apple device, or an account to RSVP to an event.","CloudOS.LandingPage.Invites.FAQ.D.Title":"What is iCloud+?","CloudOS.LandingPage.Invites.FAQ.D.Content":"iCloud+ is a premium subscription that includes Apple Invites and provides additional storage to keep your photos, videos, files, and more backed up and automatically available across your devices. It also includes access to features like iCloud Private Relay, Hide My Email, Custom Email Domain, and HomeKit Secure Video for an even more private and connected experience.","CloudOS.Authentication.SignIn.Button":"Sign In","CloudOS.Authentication.SignIn.AppleIdView.Title":"Sign in with Apple Account","CloudOS.Authentication.SignIn.ShareAcceptance.Title":"Shared via iCloud","CloudOS.Authentication.SignIn.ShareAcceptance.Open.Subtitle":"You need an Apple Account to access this file.","CloudOS.Authentication.SignIn.ShareAcceptance.Manage.Subtitle":"Sign in with your Apple Account to review access.","CloudOS.Authentication.SignIn.ShareAcceptance.CreateDescription":"If you don’t have an Apple Account, create one for free.","CloudOS.Authentication.SignIn.ShareAcceptance.CreateButton":"Create Apple Account","CloudOS.Authentication.SignIn.ShareAcceptance.CreateAriaLabel":"Create Apple Account","CloudOS.Authentication.SignInButton.Title":"Sign In","CloudOS.Authentication.SignOutButton.Title":"Sign Out","CloudOS.Authentication.TrustBrowserAndSignOutButton.Title":"Trust and Sign Out","CloudOS.Authentication.TrustBrowser.SignOut.Title":"Sign Out of iCloud.com?","CloudOS.Authentication.TrustBrowser.SignOut.Description":"If you trust this browser, you will not be asked for a verification code the next time you sign in.","CloudOS.Authentication.QuickAccess.Title":"If you can’t enter a code because you’ve lost your device, you can use Find Devices to locate it or Manage Devices to remove your Apple Pay cards from it.","CloudOS.Authentication.QuickAccess.ManageDevices.Title":"Manage Devices","CloudOS.Authentication.QuickAccess.FMIP.Title":"Find Devices","CloudOS.Authentication.WebAccessBlockedQuickAccess.Title":"Lost a device?","CloudOS.Error.UnableToLoadApp.Title":"Unable to load %{applicationName}","CloudOS.Error.UnableToLoadiCloud.Title":"Unable to load iCloud","CloudOS.Error.UnableToLoadApp.iCloudLiteAccount.Description":"Your Apple Account %{appleId} is unable to view %{applicationTitle}. Please sign in with the Apple Account used on your device.","CloudOS.Application.Title":"this application","CloudOS.AccountInfoMenuView.ManagedId.Title":"Manage Apple Account","CloudOS.Help.Title":"Help","CloudOS.Error.TermsUpdateRequired.Title":"Terms and Conditions","CloudOS.Error.TermsUpdateRequired.Description":"In order to proceed, please accept the iCloud terms and conditions on an iOS or macOS device.","CloudOS.UnsavedChanges.Alert.Title":"